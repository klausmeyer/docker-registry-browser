#!/bin/bash -e

set -x

if [[ -z "$SECRET_KEY_BASE" ]];
then
  echo "Missing SECRET_KEY_BASE variable."
  echo "Generate a unique and strong value with: openssl rand -hex 64"
  echo ""

  exit 1
fi

if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  export HTTP_PORT=${PORT}
  export HTTPS_PORT=${SSL_PORT}
  unset PORT
  unset SSL_PORT

  echo "HTTP_PORT: ${HTTP_PORT}, HTTPS_PORT: ${HTTPS_PORT}, PORT: ${PORT}, SSL_PORT: ${SSL_PORT}"
fi

exec "${@}"
